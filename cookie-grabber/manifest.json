{
  "manifest_version": 3,
  "name": "Shopee Affiliate Cookie Sync",
  "version": "1.2.0",
  "description": "Proxy Shopee Affiliate API calls qua browser context, tránh bot-detection. Đồng bộ cookie tới local server.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://affiliate.shopee.vn/*",
    "https://shopee.vn/*",
    "https://*.shopee.vn/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shopee Affiliate Cookie Sync"
  }
}
